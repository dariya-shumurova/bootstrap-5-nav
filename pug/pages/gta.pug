block content
    header 
        .dota-box 
          .container-xl.p-0 
             .container
                  .row 
                      .col-xxl-6.col-xl-6.col-lg-6.col-md-12 
                          .hero-section.pt-5 
                              h1.hero-title.text-white.m-0 gta 2
